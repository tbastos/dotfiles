#!/bin/bash
set -euo pipefail

CACHE_DIR="$HOME/.cache/app-icons"
mkdir -p "$CACHE_DIR"

apply_icon() {
  local app_name="$1"
  local icon_url="$2"
  local app_path="/Applications/$app_name.app"
  local icns_file="$CACHE_DIR/$app_name.icns"

  if [[ ! -d "$app_path" ]]; then
    echo "skip: $app_name not found at $app_path"
    return
  fi

  if [[ ! -f "$icns_file" ]]; then
    echo "downloading: $app_name"
    curl -fsSL -o "$icns_file" "$icon_url"
  fi

  echo "applying: $app_name"
  osascript -l JavaScript -e "
    ObjC.import('AppKit');
    var image = $.NSImage.alloc.initByReferencingFile('$icns_file');
    $.NSWorkspace.sharedWorkspace.setIconForFileOptions(image, '$app_path', 0);
  "
}

apply_icon "WezTerm" \
  "https://s3.macosicons.com/macosicons/icons/Iz0UicfSdB/icnsFile_605217899b371b18c02412b22866ea9f_WezTerm.icns"

echo "done"
